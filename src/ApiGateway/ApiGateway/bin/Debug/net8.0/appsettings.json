{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Debug"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/user/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "quantity-route": {
        "ClusterId": "quantity-cluster",
        "Match": {
          "Path": "/quantity/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "history-route": {
        "ClusterId": "history-cluster",
        "Match": {
          "Path": "/history/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user-destination": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "quantity-cluster": {
        "Destinations": {
          "quantity-destination": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "history-cluster": {
        "Destinations": {
          "history-destination": {
            "Address": "http://localhost:5004/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}