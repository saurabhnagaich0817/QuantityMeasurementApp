{
  "ReverseProxy": {
    "Routes": [
      {
        "RouteId": "authRoute",
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/auth" }
        ]
      },
      {
        "RouteId": "userRoute",
        "ClusterId": "userCluster",
        "Match": {
          "Path": "/user/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/user" }
        ]
      },
      {
        "RouteId": "quantityRoute",
        "ClusterId": "quantityCluster",
        "Match": {
          "Path": "/quantity/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/quantity" }
        ]
      },
      {
        "RouteId": "historyRoute",
        "ClusterId": "historyCluster",
        "Match": {
          "Path": "/history/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/history" }
        ]
      }
    ],
    "Clusters": {
      "authCluster": {
        "Destinations": {
          "authDestination": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "userCluster": {
        "Destinations": {
          "userDestination": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "quantityCluster": {
        "Destinations": {
          "quantityDestination": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "historyCluster": {
        "Destinations": {
          "historyDestination": {
            "Address": "http://localhost:5004/"
          }
        }
      }
    }
  }
}